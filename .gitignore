# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# cache
src/data/cache/
src/data/meetings/

# vercel
.vercel

# local
.claude/
.playwright-mcp/
.pipeline-artifacts/

# typescript
*.tsbuildinfo
next-env.d.ts

# build artifacts
design-variations/

# screenshots (large, docs/images/ has curated set)
screenshots/

# mobile build artifacts
mobile/node_modules/
mobile/dist/
mobile/android/
mobile/.expo/

# unused Next.js template SVGs
public/file.svg
public/globe.svg
public/next.svg
public/vercel.svg
public/window.svg
